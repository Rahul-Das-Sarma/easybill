# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."

# Legacy (optional): still read if publishable key is unset
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Server-only: upload invoice PDFs & create signed URLs (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY="[service-role-secret]"

# Storage bucket for generated PDFs (create as private in Supabase Dashboard)
SUPABASE_INVOICE_PDF_BUCKET="invoice-pdfs"
# Storage bucket for company logos (typically public for direct rendering)
SUPABASE_COMPANY_LOGO_BUCKET="company-logos"

# Email (https://resend.com)
RESEND_API_KEY="re_..."
# Optional; default is Resend onboarding sender
# RESEND_FROM_EMAIL="EasyBill <billing@yourdomain.com>"

# Supabase — Project Settings → Database
#
# For Prisma migrations, use a direct Postgres URL (Session pooler :5432 or direct host).
# PgBouncer transaction mode (:6543) can break migrations — point DATABASE_URL at direct
# for `npm run db:migrate`, or add `directUrl` in prisma/schema.prisma and set both URLs.

DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
