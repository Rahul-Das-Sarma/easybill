# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."

# Legacy (optional): still read if publishable key is unset
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase — Project Settings → Database
#
# For Prisma migrations, use a direct Postgres URL (Session pooler :5432 or direct host).
# PgBouncer transaction mode (:6543) can break migrations — point DATABASE_URL at direct
# for `npm run db:migrate`, or add `directUrl` in prisma/schema.prisma and set both URLs.

DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
